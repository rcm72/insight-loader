* text=auto

# Keep text files normalized as LF in working tree and repo
*.sql text eol=lf
*.md text eol=lf
*.py text eol=lf
*.cql text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.txt text eol=lf

# Windows script files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
